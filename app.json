{
  "expo": {
    "name": "해피야나비야",
    "slug": "happyandnavi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FAF3E0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.happyandnavi.app",
      "infoPlist": {
        "NSCameraUsageDescription": "반려동물 사진을 촬영하기 위해 카메라 접근이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "반려동물 사진을 선택하기 위해 사진첩 접근이 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF3E0"
      },
      "package": "com.happyandnavi.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "scheme": "happyandnavi",
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ]
  }
}
